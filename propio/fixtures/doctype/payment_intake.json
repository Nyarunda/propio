{
 "doctype": "DocType",
 "name": "Payment Intake",
 "module": "Propio",
 "custom": 0,
 "istable": 0,
 "is_submittable": 0,
 "track_changes": 1,
 "allow_rename": 0,
 "autoname": "format:PAYIN-{YYYY}-{#####}",
 "title_field": "payment_reference",
 "search_fields": "payment_reference,tenant,raw_reference",
 "sort_field": "modified",
 "sort_order": "DESC",
 "fields": [
  {
   "fieldname": "payment_reference",
   "label": "Payment Reference",
   "fieldtype": "Data",
   "reqd": 1,
   "unique": 1,
   "in_list_view": 1,
   "in_standard_filter": 1
  },
  {
   "fieldname": "status",
   "label": "Status",
   "fieldtype": "Select",
   "options": "\nDraft\nReceived\nMatched\nPartially Matched\nUnmatched\nPosted\nRejected",
   "default": "Draft",
   "reqd": 1,
   "read_only": 1,
   "in_list_view": 1,
   "in_standard_filter": 1
  },
  {
   "fieldname": "sb_header",
   "label": "Payment Header",
   "fieldtype": "Section Break"
  },
  {
   "fieldname": "tenant",
   "label": "Tenant",
   "fieldtype": "Link",
   "options": "Tenant",
   "reqd": 1,
   "in_standard_filter": 1
  },
  {
   "fieldname": "company",
   "label": "Company",
   "fieldtype": "Link",
   "options": "Company",
   "reqd": 1,
   "in_standard_filter": 1
  },
  {
   "fieldname": "cb_header_1",
   "fieldtype": "Column Break"
  },
  {
   "fieldname": "payment_channel",
   "label": "Payment Channel",
   "fieldtype": "Select",
   "options": "\nM-Pesa\nBank Transfer\nCheque\nCash\nCard\nEFT\nRTGS\nSWIFT\nStanding Order\nOther",
   "reqd": 1,
   "in_standard_filter": 1
  },
  {
   "fieldname": "currency",
   "label": "Currency",
   "fieldtype": "Link",
   "options": "Currency",
   "reqd": 1
  },
  {
   "fieldname": "amount",
   "label": "Amount",
   "fieldtype": "Currency",
   "options": "currency",
   "reqd": 1
  },
  {
   "fieldname": "payment_date",
   "label": "Payment Date",
   "fieldtype": "Datetime",
   "reqd": 1
  },
  {
   "fieldname": "raw_reference",
   "label": "Raw Reference",
   "fieldtype": "Data",
   "in_list_view": 1
  },
  {
   "fieldname": "bank_account",
   "label": "Bank Account",
   "fieldtype": "Link",
   "options": "Bank Account"
  },
  {
   "fieldname": "cheque_no",
   "label": "Cheque No",
   "fieldtype": "Data",
   "mandatory_depends_on": "eval:doc.payment_channel == 'Cheque'"
  },
  {
   "fieldname": "mpesa_code",
   "label": "M-Pesa Code",
   "fieldtype": "Data",
   "mandatory_depends_on": "eval:doc.payment_channel == 'M-Pesa'"
  },
  {
   "fieldname": "sb_allocation",
   "label": "Payment Allocation",
   "fieldtype": "Section Break"
  },
  {
   "fieldname": "allocations",
   "label": "Allocations",
   "fieldtype": "Table",
   "options": "Payment Intake Allocation"
  },
  {
   "fieldname": "payment_entry",
   "label": "Payment Entry",
   "fieldtype": "Link",
   "options": "Payment Entry",
   "read_only": 1
  },
  {
   "fieldname": "sb_notes",
   "label": "Notes",
   "fieldtype": "Section Break"
  },
  {
   "fieldname": "remarks",
   "label": "Remarks",
   "fieldtype": "Small Text"
  }
 ],
 "permissions": [
  {"role": "System Manager", "read": 1, "write": 1, "create": 1, "delete": 1},
  {"role": "Administrator", "read": 1, "write": 1, "create": 1, "delete": 1},
  {"role": "Accountant", "read": 1, "write": 1, "create": 1, "delete": 0},
  {"role": "Collections Officer", "read": 1, "write": 1, "create": 1, "delete": 0},
  {"role": "Property Manager", "read": 1, "write": 0, "create": 0, "delete": 0},
  {"role": "Portfolio Director", "read": 1, "write": 0, "create": 0, "delete": 0}
 ]
}
