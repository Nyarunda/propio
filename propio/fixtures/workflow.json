[
 {
  "doctype": "Workflow",
  "name": "Lease Workflow",
  "workflow_name": "Lease Workflow",
  "document_type": "Lease",
  "is_active": 1,
  "send_email_alert": 1,
  "workflow_state_field": "status",
  "states": [
   {
    "state": "Draft",
    "doc_status": "0",
    "allow_edit": "Leasing Officer"
   },
   {
    "state": "Pending Approval",
    "doc_status": "0",
    "allow_edit": "Property Manager"
   },
   {
    "state": "Approved",
    "doc_status": "0",
    "allow_edit": "Portfolio Director"
   },
   {
    "state": "Active",
    "doc_status": "1",
    "allow_edit": "Property Manager"
   },
   {
    "state": "Expiring Soon",
    "doc_status": "1",
    "allow_edit": "Property Manager"
   },
   {
    "state": "Renewed",
    "doc_status": "1",
    "allow_edit": "Leasing Officer"
   },
   {
    "state": "Terminated",
    "doc_status": "1",
    "allow_edit": "Property Manager"
   },
   {
    "state": "Closed",
    "doc_status": "1",
    "allow_edit": "Property Manager"
   },
   {
    "state": "Rejected",
    "doc_status": "0",
    "allow_edit": "Leasing Officer"
   }
  ],
  "transitions": [
   {
    "action": "Submit for Approval",
    "state": "Draft",
    "next_state": "Pending Approval",
    "allowed": "Leasing Officer",
    "allow_self_approval": 1,
    "condition": "doc.lease_units and doc.lease_charges"
   },
   {
    "action": "Approve",
    "state": "Pending Approval",
    "next_state": "Approved",
    "allowed": "Property Manager",
    "condition": "doc.tenant and doc.property"
   },
   {
    "action": "Reject",
    "state": "Pending Approval",
    "next_state": "Rejected",
    "allowed": "Property Manager",
    "condition": ""
   },
   {
    "action": "Activate Lease",
    "state": "Approved",
    "next_state": "Active",
    "allowed": "Property Manager",
    "condition": "doc.start_date"
   },
   {
    "action": "Mark Expiring",
    "state": "Active",
    "next_state": "Expiring Soon",
    "allowed": "System Manager",
    "condition": "doc.end_date"
   },
   {
    "action": "Renew Lease",
    "state": "Expiring Soon",
    "next_state": "Renewed",
    "allowed": "Leasing Officer",
    "condition": ""
   },
   {
    "action": "Terminate",
    "state": "Active",
    "next_state": "Terminated",
    "allowed": "Property Manager",
    "condition": ""
   },
   {
    "action": "Close",
    "state": "Terminated",
    "next_state": "Closed",
    "allowed": "Property Manager",
    "condition": ""
   },
   {
    "action": "Reopen",
    "state": "Closed",
    "next_state": "Active",
    "allowed": "System Manager",
    "condition": ""
   }
  ]
 },
 {
